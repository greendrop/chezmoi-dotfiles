// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "copilot"
  },
  "terminal": {
    "font_family": ".ZedMono",
    "font_features": {
      "calt": false,
      "liga": false,
      "dlig": false,
    },
  },
  "vim": {
    "use_system_clipboard": "never",
  },
  "vim_mode": true,
  "cli_default_open_behavior": "new_window",
  "agent": {
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "ui_font_features": {
    "calt": false,
    "liga": false,
    "dlig": false,
  },
  "buffer_font_size": 15,
  "buffer_font_features": {
    "calt": false,
    "liga": false,
    "dlig": false,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
